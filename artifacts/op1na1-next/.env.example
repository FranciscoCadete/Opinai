# Database (Neon pooler URL)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# JWT — must match between middleware.ts and server/auth.ts
AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars

# Set to "true" to run without a database (demo credentials: admin@mulenvos.ao / demo1234)
NEXT_PUBLIC_DEMO_MODE=false

# CORS (production domain)
NEXT_PUBLIC_APP_URL=https://op1na1.gov.ao

# ── Notificações Proativas ────────────────────────────────────────

# Resend — transactional email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=OP1NA1 <notificacoes@mulenvos.ao>

# Twilio — SMS outbound (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+244XXXXXXXXX

# WhatsApp Business Cloud API (https://developers.facebook.com)
# Template "op1na1_status_update" must be pre-approved by Meta (Category: UTILITY, Language: pt_PT)
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
