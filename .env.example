# ─────────────────────────────────────────────────────────────────────────────
# OP1NA1 — variáveis de ambiente
# Copie para .env (local) ou configure no painel da Vercel (Production/Preview).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Postgres ────────────────────────────────────────────────────────────────
# Recomenda-se Neon (https://neon.tech) com pooler URL.
# Para Vercel Functions, USE SEMPRE a connection string com pooler.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ────────────────────────────────────────────────────────────────────
# 32+ caracteres aleatórios (ex.: openssl rand -hex 48)
AUTH_SECRET=change-me-to-a-long-random-string-32chars-min
SEED_ADMIN_EMAIL=admin@op1na1.local
SEED_ADMIN_PASSWORD=ChangeMe!2025
SEED_TECHNICIAN_EMAIL=tecnico@op1na1.local
SEED_TECHNICIAN_PASSWORD=ChangeMe!2025

# ─── HTTP ────────────────────────────────────────────────────────────────────
# CORS: restringir em produção ao domínio público (ex.: https://op1na1.gov.ao)
CORS_ORIGIN=*
VITE_API_BASE=/api

# ─── Vite dev (apenas local) ─────────────────────────────────────────────────
PORT=5173
BASE_PATH=/

# ─── Meta (WhatsApp + Messenger) ─────────────────────────────────────────────
# Configurar em developers.facebook.com → App → WhatsApp / Messenger
# https://developers.facebook.com/docs/whatsapp/cloud-api
# https://developers.facebook.com/docs/messenger-platform

# App secret (mesmo para ambos os produtos da mesma App)
META_APP_SECRET=

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=                # qualquer string privada (usada no GET handshake)
WHATSAPP_ACCESS_TOKEN=                # token permanente (de System User)
WHATSAPP_PHONE_NUMBER_ID=             # ID do número de telefone do WA Business

# Messenger
MESSENGER_VERIFY_TOKEN=                # qualquer string privada
MESSENGER_PAGE_ACCESS_TOKEN=           # Page Access Token (Page → Settings)

# ─── Twilio (SMS) ────────────────────────────────────────────────────────────
# console.twilio.com → Account SID + Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=                   # número Twilio (ex.: +1XXXXXXXXXX)
# Em testes locais com ngrok pode ser preciso forçar a URL pública:
# TWILIO_WEBHOOK_URL_OVERRIDE=https://abc123.ngrok.io/api/channels/sms/webhook
# Em ambiente de desenvolvimento podemos ignorar a assinatura (NUNCA em prod):
# TWILIO_SKIP_SIGNATURE=true

# ─── USSD (Africa's Talking) ─────────────────────────────────────────────────
# https://account.africastalking.com → USSD → criar service code
# A AT não assina os webhooks por defeito — usar IP allowlist no firewall
# OU partilhar um segredo via header X-Shared-Secret (configurar na AT também):
USSD_SHARED_SECRET=

# ─── Anthropic Claude (NLP classification) ──────────────────────────────────
# console.anthropic.com → API Keys
# Sem esta chave, o sistema cai automaticamente para a heurística de palavras-chave.
# Modelo usado: claude-haiku-4-5 (custo ~$0.0002 por classificação)
# Latência típica: 1-3s. Timeout configurado: 5s.
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Fase futura — filas:
# ─────────────────────────────────────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# QSTASH_TOKEN=
